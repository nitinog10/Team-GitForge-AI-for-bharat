{
  "name": "docuverse-ai",
  "displayName": "DocuVerse AI",
  "description": "AI explains your code with audio walkthroughs, diagrams & impact analysis — like a YouTube video for code",
  "version": "0.1.0",
  "publisher": "docuverse",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Education",
    "Visualization"
  ],
  "keywords": [
    "documentation",
    "walkthrough",
    "AI",
    "code-analysis",
    "diagrams"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docuverse.login",
        "title": "Sign In with GitHub",
        "icon": "$(sign-in)",
        "category": "DocuVerse"
      },
      {
        "command": "docuverse.logout",
        "title": "Sign Out",
        "icon": "$(sign-out)",
        "category": "DocuVerse"
      },
      {
        "command": "docuverse.connectRepo",
        "title": "Connect Repository",
        "icon": "$(repo-clone)",
        "category": "DocuVerse"
      },
      {
        "command": "docuverse.quickAction",
        "title": "Quick Actions...",
        "icon": "$(zap)",
        "category": "DocuVerse"
      },
      {
        "command": "docuverse.explainFile",
        "title": "Explain This File",
        "icon": "$(play)",
        "category": "DocuVerse"
      },
      {
        "command": "docuverse.showImpact",
        "title": "What Breaks If I Change This?",
        "icon": "$(warning)",
        "category": "DocuVerse"
      },
      {
        "command": "docuverse.generateDiagram",
        "title": "Visualize as Diagram",
        "icon": "$(type-hierarchy)",
        "category": "DocuVerse"
      },
      {
        "command": "docuverse.generateDocs",
        "title": "Generate Documentation",
        "icon": "$(book)",
        "category": "DocuVerse"
      },
      {
        "command": "docuverse.runSandbox",
        "title": "Run Selection in Sandbox",
        "icon": "$(play)",
        "category": "DocuVerse"
      },
      {
        "command": "docuverse.refreshExplorer",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "DocuVerse"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "docuverse",
          "title": "DocuVerse AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "docuverse": [
        {
          "id": "docuverse-welcome",
          "name": "DocuVerse AI",
          "type": "webview",
          "when": "!docuverse.isLoggedIn"
        },
        {
          "id": "docuverse-hub",
          "name": "DocuVerse AI",
          "type": "webview",
          "when": "docuverse.isLoggedIn"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "submenu": "docuverse.submenu",
          "group": "docuverse"
        }
      ],
      "docuverse.submenu": [
        {
          "command": "docuverse.explainFile",
          "group": "1_main@1"
        },
        {
          "command": "docuverse.showImpact",
          "group": "1_main@2"
        },
        {
          "command": "docuverse.generateDiagram",
          "group": "1_main@3"
        },
        {
          "command": "docuverse.runSandbox",
          "group": "2_run@1"
        }
      ]
    },
    "submenus": [
      {
        "id": "docuverse.submenu",
        "label": "DocuVerse AI"
      }
    ],
    "configuration": {
      "title": "DocuVerse AI",
      "properties": {
        "docuverse.apiUrl": {
          "type": "string",
          "default": "https://xpbgkuukxp.ap-south-1.awsapprunner.com/api",
          "description": "Backend API URL (change to http://localhost:8000/api for local dev)"
        },
        "docuverse.defaultViewMode": {
          "type": "string",
          "enum": [
            "developer",
            "manager"
          ],
          "default": "developer",
          "description": "Walkthrough style — 'developer' (technical) or 'manager' (business summary)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "webpack --mode production --devtool hidden-source-map",
    "webpack": "webpack --mode development",
    "webpack-dev": "webpack --mode development --watch",
    "lint": "eslint src --ext ts",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
